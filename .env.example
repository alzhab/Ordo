# Обязательные
TELEGRAM_BOT_TOKEN=        # @BotFather → создать бота
GROQ_API_KEY=              # console.groq.com (Whisper, бесплатно)
ANTHROPIC_API_KEY=         # console.anthropic.com (парсинг задач)

# Google Calendar (опционально)
# 1. console.cloud.google.com → создать проект → OAuth 2.0 Client ID (тип: Web application)
# 2. Authorized redirect URIs → добавить: https://<домен>/oauth/google/callback
# 3. Заполнить переменные ниже + PORT (Railway выставляет автоматически)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=       # https://your-app.railway.app/oauth/google/callback

# Notion (опционально)
NOTION_TOKEN=              # Notion integration token
NOTION_DATABASE_ID=        # ID базы задач (прод)
NOTION_PLANS_DATABASE_ID=  # ID базы планов (прод)

# Dev-режим (опционально, DEV=true использует data_dev.db и dev Notion базы)
# DEV=true
NOTION_DATABASE_ID_DEV=
NOTION_PLANS_DATABASE_ID_DEV=
